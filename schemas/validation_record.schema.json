{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aevespers2/Bridge/schemas/validation_record.schema.json",
  "title": "Bridge Validation Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "target_id", "target_type", "validation_status", "validated_at", "provenance"],
  "properties": {
    "id": {"type": "string"},
    "target_id": {"type": "string"},
    "target_type": {
      "type": "string",
      "enum": ["request", "observation", "claim", "document", "event"]
    },
    "validation_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "UNKNOWN"]
    },
    "validated_at": {"type": "string"},
    "supporting_refs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "contradicting_refs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "validation_errors": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "provenance": {"type": "object"}
  }
}
